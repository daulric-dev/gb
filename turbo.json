{
  "$schema": "https://v2-9-7.turborepo.dev/schema.json",
  "globalEnv": [
    "FRONTEND_URL",
    "PORT",
    "REDIS_URL",
    "SUPABASE_URL",
    "SUPABASE_PUSHABLE_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "USE_REDIS"
  ],
  "tasks": {
    "build": {
      "outputs": [".next/**", "dist/**", "build/**"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start:dev": {
      "cache": false,
      "persistent": true
    },
    "start:prod": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}