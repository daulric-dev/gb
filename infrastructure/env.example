# Copy to `.env` in this folder (infrastructure/.env is gitignored) and fill in.
#   cp env.example .env
#
# These are loaded into all three app replicas via `env_file` in
# docker-compose.yml. PORT, USE_REDIS and REDIS_URL are set by Compose itself
# (per-replica PORT; Redis points at the in-cluster `redis` service) and do not
# belong here.

# --- Supabase ---------------------------------------------------------------
# Production: your hosted project URL + keys.
# Local dev:  point at the Supabase running on your host. From inside a
#             container, localhost is the container, so use host.docker.internal:
#             SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUSHABLE_KEY=

# --- App --------------------------------------------------------------------
# Used for cookie domain / CORS. e.g. https://app.example.com
FRONTEND_URL=
NODE_ENV=production

# Set to "true" only for a single-tenant dedicated deployment (see code).
DEDICATED_DEPLOYMENT=false
