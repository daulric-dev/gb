{
    "name": "gb",
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "turbo": "^2.9.16"
    },
    "private": true,
    "packageManager": "bun@1.3.13",
    "bin": {
        "gb": "./command/index.ts"
    },
    "scripts": {
        "gb": "bun ./command/index.ts",
        "dev": "supabase start && turbo run dev start:dev",
        "dev:frontend": "turbo run dev --filter=frontend",
        "dev:backend": "turbo run start:dev --filter=backend",
        "build": "turbo run build",
        "build:frontend": "turbo run build --filter=frontend",
        "build:backend": "turbo run build --filter=backend",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "test:frontend": "turbo run test --filter=frontend",
        "test:backend": "turbo run test --filter=backend",
        "preview": "supabase start && turbo run start:prod",
        "db:start": "supabase start",
        "db:stop": "supabase stop",
        "db:types": "cd backend && chmod +x ./scripts/gen_types.sh && ./scripts/gen_types.sh",
        "dev:docs": "turbo run dev --filter=docs",
        "build:docs": "turbo run build --filter=docs",
        "db:diff": "supabase db diff --schema '*',storage -f",
        "db:pull": "supabase db pull --schema '*',storage"
    },
    "workspaces": ["backend", "frontend", "docs"],
    "overrides": {
        "webpackbar": "^7.0.0"
    },
    "dependencies": {
        "typescript": "^6.0.3"
    }
}
